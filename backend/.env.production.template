# ============================================
# BACKEND - Variables de Entorno PRODUCCIÓN
# ============================================
# Copiar este archivo a .env y configurar los valores reales

# ─── BASE DE DATOS (OBLIGATORIO) ───
# MongoDB Atlas o servidor dedicado
MONGO_URL="mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="revix_production"

# ─── SEGURIDAD (OBLIGATORIO) ───
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="CAMBIAR_POR_SECRETO_SEGURO_DE_64_CARACTERES"

# ─── CORS (OBLIGATORIO) ───
# Lista de dominios permitidos separados por coma
CORS_ORIGINS="https://revix.es,https://app.revix.es,https://www.revix.es"

# ─── TWILIO (SMS) ───
TWILIO_ACCOUNT_SID="tu_account_sid"
TWILIO_AUTH_TOKEN="tu_auth_token"
TWILIO_PHONE_NUMBER="+34xxxxxxxxx"

# ─── SENDGRID (Email alternativo) ───
SENDGRID_API_KEY="SG.xxxxx"
SENDGRID_FROM_EMAIL="notificaciones@revix.es"

# ─── SMTP (Email principal) ───
SMTP_HOST="mail.privateemail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="notificaciones@revix.es"
SMTP_PASS="tu_password_smtp"
SMTP_FROM="Revix <notificaciones@revix.es>"
SMTP_REPLY_TO="help@revix.es"

# ─── LLM (Chatbot IA) ───
EMERGENT_LLM_KEY="tu_emergent_key"

# ─── SUMBROKER/INSURAMA (opcional) ───
SUMBROKER_LOGIN="tu_login"
SUMBROKER_PASSWORD="tu_password"

# ─── URLs ───
FRONTEND_URL="https://revix.es"
