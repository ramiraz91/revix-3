# =============================================================
# Revix - Mobile Repair CRM/ERP - Configuración de Entorno
# =============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ── MongoDB Atlas ─────────────────────────────────────────────
# Formato: mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
# Lo encuentras en Atlas → tu cluster → Connect → Drivers
MONGO_URL=mongodb+srv://tuusuario:tupassword@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://tuusuario:tupassword@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos
DB_NAME=production

# ── IMPORTANTE para Emergent ──────────────────────────────────
# Emergent usa internamente la variable MONGO_URL.
# Añade esta misma variable en el panel de entorno de Emergent.

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── JWT / Seguridad ───────────────────────────────────────────
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui_minimo_32_chars

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=https://tu-dominio.com

# ── SMTP (Email) ──────────────────────────────────────────────
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=tu_password_smtp
SMTP_FROM=Revix <notificaciones@tudominio.com>
SMTP_REPLY_TO=help@tudominio.com

# ── Cloudinary (Imágenes) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Emergent LLM Key (IA) ─────────────────────────────────────
EMERGENT_LLM_KEY=sk-emergent-xxxxx

# ── Acceso de emergencia ──────────────────────────────────────
EMERGENCY_ACCESS_KEY=genera_una_clave_segura_aqui
